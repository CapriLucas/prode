# Base de datos PostgreSQL
DATABASE_URL=postgresql://prode:prode@localhost:5432/prode

# odds-api.io — obtené tu clave en https://odds-api.io
ODDS_API_KEY_IO=

# Configuración del proveedor de odds (valores por defecto ya correctos)
ODDS_API_IO_BASE_URL=https://api.odds-api.io/v3
ODDS_API_IO_SPORT=football
ODDS_API_IO_LEAGUE=international-fifa-world-cup

# Contraseña de PostgreSQL en docker-compose (opcional, default: prode)
# POSTGRES_PASSWORD=cambia_esto_en_produccion
